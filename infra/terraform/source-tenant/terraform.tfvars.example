# Run by a SOURCE-tenant admin. Copy to terraform.tfvars and adjust.


source_tenant_id = "REPLACE_ME" # Entra tenant ID of the SOURCE tenant

# From the target admin: `terraform output migration_app_client_id` of the
# target-tenant stack (non-secret GUID).
migration_app_client_id = "REPLACE_ME"

platform_app_client_id = "REPLACE_ME" # client ID of the source tenant platform app registration

