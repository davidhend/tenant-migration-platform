# Run by a TARGET-tenant admin. Copy to terraform.tfvars and adjust.
# Example values for the TARGET tenant of a migration pair.

target_tenant_id = "REPLACE_ME" # Entra tenant ID of the TARGET tenant
source_tenant_id = "REPLACE_ME" # SOURCE Entra tenant ID (consent-URL output only)

platform_app_client_id = "REPLACE_ME" # client ID of the target tenant platform app registration

